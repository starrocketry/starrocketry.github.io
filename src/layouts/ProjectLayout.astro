---
import Layout from "./Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/project-page.css";

const { frontmatter } = Astro.props;
---

<Layout title={`${frontmatter.title} | Technical Report`}>
  <Navbar />

  <article class="project-page">
    <header class="project-hero">
      <div class="hero-bg">
        <img src={frontmatter.image} alt="" />
        <div class="hero-overlay"></div>
      </div>

      <div class="hero-content">
        <nav class="breadcrumb">
          <a href="/projects">/ MISSION_MANIFEST</a>
        </nav>
        <div class="meta-badge">SYSTEM_DATA_REPORT</div>
        <h1 class="project-title">{frontmatter.title}</h1>
        <div class="project-meta-strip">
          <div class="meta-item">
            <span class="label">FILE_ID</span>
            <span class="value">{frontmatter.id}</span>
          </div>
          <div class="meta-item">
            <span class="label">CATEGORY</span>
            <span class="value">{frontmatter.category}</span>
          </div>
          <div class="meta-item">
            <span class="label">STATUS</span>
            <span class={`value status-${frontmatter.status?.toLowerCase()}`}>
              {frontmatter.status || "OPERATIONAL"}
            </span>
          </div>
        </div>
      </div>
    </header>

    <div class="project-body-wrapper">
      <aside class="tactical-sidebar">
        <div class="sidebar-box glass">
          <h3>ARCHIVE_INFO</h3>
          <ul>
            <li>
              <span>ORIGIN:</span>
              {frontmatter.origin || "GROUND_CONTROL"}
            </li>
            <li>
              <span>CLEARANCE:</span>
              {frontmatter.clearance || "LEVEL_01"}
            </li>
            <li><span>ENCRYPTION:</span> {frontmatter.encryption || "NONE"}</li>
          </ul>
        </div>
        <div class="sidebar-box glass">
          <h3>TELEMETRY</h3>
          <div class="stat-row">
            <div class="stat-bar">
              <div
                class="fill"
                style={`width: ${frontmatter.integrity || 0}%;`}
              >
              </div>
            </div>
            <span class="stat-label"
              >DATA_INTEGRITY {frontmatter.integrity || 0}%</span
            >
          </div>
        </div>
      </aside>

      <section class="markdown-content">
        <slot />
      </section>
    </div>
  </article>

  <Footer />
</Layout>
