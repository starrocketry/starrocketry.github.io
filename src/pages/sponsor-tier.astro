---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

import sponsorsData from "./data/sponsors.json";
import "../styles/sponsor-tier.css";

const tiers = [
  {
    id: "static_fire",
    name: "STATIC FIRE",
    currency: "INR",
    price: "50k - 1L",
    impact: "Cansat.",
    color: "#ffffff",
  },
  {
    id: "max_q",
    name: "MAX-Q",
    currency: "INR",
    price: "1L+",
    impact: "Enables development of L2 HPR and CanSat",
    color: "#ffffff",
  },
  {
    id: "apogee",
    name: "APOGEE",
    currency: "INR",
    price: "5L+",
    impact:
      "Helps us participate in Rocketry competitions such as IN-SPACe and IREC",
    color: "#ffffff",
  },
  {
    id: "escape_velocity",
    name: "ESCAPE VELOCITY",
    currency: "",
    price: "CUSTOM",
    impact:
      "Exclusive naming rights for primary launch vehicles and long-term R&D.",
    color: "#C594F0",
  },
];

const benefits = [
  {
    label: "Logo on Website & Newsletters",
    static_fire: "✦",
    max_q: "✦",
    apogee: "✦",
    escape_velocity: "✦",
  },
  {
    label: "Logo on CanSat",
    static_fire: "✦",
    max_q: "✦",
    apogee: "✦",
    escape_velocity: "✦",
  },
  {
    label: "Logo on Rocket Airframe",
    static_fire: "Small",
    max_q: "Medium",
    apogee: "Large",
    escape_velocity: "Large",
  },
  {
    label: "Logo on Team Apparel",
    static_fire: "Small",
    max_q: "Medium",
    apogee: "Large",
    escape_velocity: "Large",
  },
  {
    label: "Name on Papers",
    static_fire: "",
    max_q: "✦",
    apogee: "✦",
    escape_velocity: "✦",
  },
  {
    label: "Name on Papers and Uploaded Reports",
    static_fire: "",
    max_q: "",
    apogee: "",
    escape_velocity: "✦",
  },
  {
    label: "Social Media Shout-outs",
    static_fire: "✦",
    max_q: "✦",
    apogee: "✦",
    escape_velocity: "✦",
  },
  {
    label: "Linkedin or other socials post mention",
    static_fire: "",
    max_q: "",
    apogee: "✦",
    escape_velocity: "✦",
  },
  {
    label: "Individual Social Media Thank Yous",
    static_fire: "Quarterly",
    max_q: "Monthly",
    apogee: "Bi-Weekly",
    escape_velocity: "Personalized",
  },
  {
    label: "Use Company Components",
    static_fire: "",
    max_q: "✦",
    apogee: "✦",
    escape_velocity: "✦",
  },
  {
    label: "Launch Day Access",
    static_fire: "",
    max_q: "",
    apogee: "",
    escape_velocity: "✦",
  },
];

const getSponsorsByTier = (tierId) =>
  sponsorsData.filter((s) => s.tier === tierId);
---

<Layout title="Support STAR Team">
  <Navbar />
  <main class="support-page">
    <section class="support-hero">
      <div class="section-tag">FUEL THE MISSION</div>
      <h1 class="glow-title">PARTNER WITH US</h1>
      <p class="subtitle">
        Empower the next generation of aerospace engineers. Help us push the
        boundaries of student rocketry.
      </p>
    </section>

    <section class="tiers-container">
      {
        tiers.map((tier) => (
          <div
            class={`tier-card ${tier.id === "escape_velocity" ? "unique" : ""}`}
          >
            <div class="tier-header">
              <span class="tier-rank" style={`color: ${tier.color}`}>
                {tier.name}
              </span>
              <div class="price-container">
                <h2 class="tier-price">{tier.price}</h2>
                {tier.currency && (
                  <span class="tier-currency">{tier.currency}</span>
                )}

                <span class="tier-interval">
                  {tier.id === "escape_velocity" ? "" : "/ yr"}
                </span>
              </div>
              <p class="tier-impact">{tier.impact}</p>
            </div>
            <hr class="divider" />
            <button
              onclick="document.getElementById('enlist-section').scrollIntoView({behavior: 'smooth'})"
              class="tier-btn"
            >
              Enlist Now
            </button>
          </div>
        ))
      }
    </section>

    <section class="table-section">
      <h2 class="benefits">BENEFITS COMPARISON</h2>
      <div class="table-scroll-wrapper glass">
        <table class="benefits-table">
          <thead>
            <tr>
              <th class="benefit-label">Tier Benefit</th>
              {tiers.map((t) => <th style={`color: ${t.color}`}>{t.name}</th>)}
            </tr>
          </thead>
          <tbody>
            {
              benefits.map((b) => (
                <tr>
                  <td class="benefit-label">{b.label}</td>
                  <td>{b.static_fire}</td>
                  <td>{b.max_q}</td>
                  <td>{b.apogee}</td>
                  <td style="color: #c594f0">{b.escape_velocity}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </section>

    <section class="fleet-section">
      <h2 class="form-title">CURRENT SPONSORS</h2>
      {
        tiers
          .slice()
          .reverse()
          .map((tier) => {
            const tierSponsors = getSponsorsByTier(tier.id);
            return tierSponsors.length > 0 ? (
              <div class={`tier-group ${tier.id}`}>
                <h3 class="tier-group-title" style={`color: ${tier.color}`}>
                  {tier.name}{" "}
                  <span>
                    // {tierSponsors.length.toString().padStart(2, "0")}
                  </span>
                </h3>
                <div class="sponsor-grid">
                  {tierSponsors.map((s) => (
                    <a
                      href={s.website}
                      target="_blank"
                      class="sponsor-hex-card glass"
                    >
                      <div class="logo-wrapper">
                        <img src={s.logo} alt={s.name} />
                      </div>
                      <div class="sponsor-meta">
                        <span class="hex-name">{s.name}</span>
                        <p class="hex-about">{s.about}</p>
                      </div>
                      <div class="card-status">
                        <span class="status-dot" /> ACTIVE PARTNER
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            ) : null;
          })
      }
    </section>

    <section id="enlist-section" class="form-section">
      <h2 class="form-title">ENLIST NOW</h2>
      <div class="notion-form-container">
        <iframe
          src="https://roan-kick-7a9.notion.site/ebd//f1e3cd49ef82823088ac81f90c33e52b"
          width="100%"
          height="800"
          frameborder="0"
          class="notion-iframe"></iframe>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
