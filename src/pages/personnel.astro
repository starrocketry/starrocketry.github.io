---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/personnel.css";

const team = [
  {
    name: "Dr. Shanawaz Patil",
    role: "HoD Aerospace Engineering",
    photo: "/gojo.jpg", // Placeholder
    github: "https://github.com",
    linkedin: "https://linkedin.com",
    orcid: "https://orcid.org/0000-0001-5334-9415",
    discord: "-",
  },
  {
    name: "Abhay Nandan",
    role: "President",
    photo: "/toji.png", // Placeholder
    github: "https://github.com/",
    linkedin: "https://linkedin.com/abhay-nandan-28269b299",
    orcid: "https://orcid.org/0009-0009-9636-5402",
    discord: "alpha_mail69420",
  },
  {
    name: "Akshay M",
    role: "Vice President",
    photo: "/panda.png",
    github: "https://github.com",
    linkedin: "https://linkedin.com",
    orcid: "https://orcid.org/0009-0009-5946-4444",
    discord: "beta_mail69420",
  },
  {
    name: "Dhruv K",
    role: "Technical Head",
    photo: "/denji.png",
    github: "https://github.com/dvke5",
    linkedin: "https://linkedin.com/dvke555",
    orcid: "https://orcid.org/0009-0006-3550-6644",
    discord: "delta_mail42069",
  },
  {
    name: "Kadam Athrv",
    role: "Leader",
    photo: "/shifu.png",
    github: "https://github.com/",
    linkedin: "https://linkedin.com/",
    orcid: "https://orcid.org/",
    discord: "kappa_mail69420",
  },
];
---

<Layout title="Personnel">
  <Navbar />
  <main class="team-container">
    <header class="team-header">
      <div class="badge">DIRECTORY</div>
      <h1>MISSION CONTROL</h1>
    </header>

    <div class="team-grid">
      {
        team.map((member) => (
          <div class="member-card glass">
            <div class="photo-wrapper">
              <img src={member.photo} alt={member.name} />
            </div>

            <div class="info">
              <h3>{member.name}</h3>
              <p class="role">{member.role}</p>
            </div>

            <div class="divider" />

            <div class="socials">
              <a href={member.github} target="_blank" class="social-link">
                GITHUB
              </a>
              <a href={member.linkedin} target="_blank" class="social-link">
                LINKEDIN
              </a>
              <a href={member.orcid} target="_blank" class="social-link">
                ORCiD
              </a>
              <div class="discord-tag">
                <span class="label">DISCORD:</span>
                <span class="id">{member.discord}</span>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </main>
  <Footer />
</Layout>
