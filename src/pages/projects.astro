---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/projects.css";

const allProjects = await Astro.glob("./projects/*.md");
---

<Layout title="Mission Manifest | Projects">
  <Navbar />

  <main class="projects-container">
    <header class="projects-header">
      <h1>PROJECTS</h1>
    </header>

    <div class="projects-grid">
      {
        allProjects.map((project) => (
          <a href={project.url} class="project-card glass">
            <div class="card-image">
              <img
                src={project.frontmatter.image}
                alt={project.frontmatter.title}
              />
              <div class="scanline" />
            </div>

            <div class="card-content">
              <div class="card-meta">
                <span class="project-id">
                  {project.frontmatter.id || "PRJ-UNK"}
                </span>
                <span class="project-category">
                  {project.frontmatter.category}
                </span>
              </div>
              <h2 class="project-title">{project.frontmatter.title}</h2>
              <p class="project-excerpt">{project.frontmatter.description}</p>

              <div class="card-footer">
                <span
                  class={`status-indicator ${project.frontmatter.status?.toLowerCase()}`}
                />
                <span class="action-text">
                  {project.frontmatter.status || "ACCESS_FILE"}
                </span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </main>

  <Footer />
</Layout>
