---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/projects.css";

const projectFiles = import.meta.glob("/src/pages/projects/markdown/*.md", {
  eager: true,
});
const projectsArray = Object.values(projectFiles);

const sortedProjects = projectsArray.sort((a: any, b: any) =>
  (a.frontmatter.id || "").localeCompare(b.frontmatter.id || ""),
);
---

<Layout title="Projects">
  <Navbar />
  <main class="projects-container">
    <header class="projects-header">
      <h1>PROJECTS</h1>
    </header>

    <div class="projects-grid">
      {
        sortedProjects.map((project: any) => {
          const slug = project.file.split("/").pop()?.replace(".md", "");

          return (
            <a href={`/projects/${slug}`} class="project-card glass">
              <div class="card-image">
                <img
                  src={project.frontmatter.image}
                  alt={project.frontmatter.title}
                />
                <div class="scanline" />
              </div>

              <div class="card-content">
                <div class="card-meta">
                  <span class="project-id">
                    {project.frontmatter.id || "PRJ-UNK"}
                  </span>
                  <span class="project-category">
                    {Array.isArray(project.frontmatter.category)
                      ? project.frontmatter.category.join(", ")
                      : project.frontmatter.category}
                  </span>
                </div>
                <h2 class="project-title">{project.frontmatter.title}</h2>

                {/* Description removed from here */}

                <div class="card-footer">
                  <span
                    class={`status-indicator ${project.frontmatter.status?.toLowerCase() || "pending"}`}
                  />
                  <span class="action-text">
                    {project.frontmatter.status || "ACCESS_FILE"}
                  </span>
                </div>
              </div>
            </a>
          );
        })
      }
    </div>
  </main>
  <Footer />
</Layout>
