---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

import "../styles/personnel.css";

const team = [
  {
    name: "Dr. Shanawaz Patil",
    role: "Mentor",
    photo: "/profile-picture/shanawaz-patil.png",
    github: "https://github.com/",
    linkedin: "https://www.linkedin.com/in/dr-shanawaz-patil-b5b31218a/",
    orcid: "https://orcid.org/0000-0001-5334-9415",
    discord: "-",
  },
  {
    name: "Abhay Nandan U",
    role: "Team Lead",
    photo: "/profile-picture/abhay-nandan.png",
    github: "https://github.com/",
    linkedin: "https://linkedin.com/in/abhay-nandan-28269b299",
    orcid: "https://orcid.org/0009-0009-9636-5402",
    discord: "abhaynandan",
  },
  {
    name: "Dhruv K",
    role: "Co-Team Lead",
    photo: "/profile-picture/dhruv-kakade.png",
    github: "https://github.com/dvke5",
    linkedin: "https://linkedin.com/in/dvke5",
    orcid: "https://orcid.org/0009-0006-3550-6644",
    discord: "deltakiro",
  },
  {
    name: "Akshay M",
    role: "Manufacturing Lead",
    photo: "/profile-picture/akshay.png",
    github: "https://github.com",
    linkedin: "https://linkedin.com/in/akshaym2005",
    orcid: "https://orcid.org/0009-0009-5946-4444",
    discord: "-",
  },
  {
    name: "Kadam Atharv Ravindra",
    role: "Propulsion Lead",
    photo: "/profile-picture/atharv.png",
    github: "https://github.com/atharv-kadam-08",
    linkedin: "https://www.linkedin.com/in/atharv-kadam-5aa1a2261",
    orcid: "https://orcid.org/0009-0002-3563-8795",
    discord: "-",
  },
  {
    name: "Avik Rajeev Babu",
    role: "Research and Development Lead",
    photo: "/profile-picture/avik-babu.png",
    github: "https://github.com",
    linkedin: "https://www.linkedin.com/in/avik-rajeev-babu-277342291",
    orcid: "https://orcid.org/",
    discord: "-",
  },

  {
    name: "Manish",
    role: "Avionics Lead",
    photo: "/profile-picture/manish.png",
    github: "https://github.com/AeroLord2006",
    linkedin: "https://www.linkedin.com/in/manish-t-megharaj-54674b32b",
    orcid: "https://orcid.org/my-orcid?orcid=0009-0001-9327-7513",
    discord: "-",
  },
];
---

<Layout title="Our Team">
  <Navbar />
  <main class="team-container">
    <header class="team-header">
      <div class="badge">MISSION CONTROL</div>
      <h1>OUR TEAM</h1>
    </header>

    <div class="team-grid">
      {
        team.map((member) => (
          <div class="member-card glass">
            <div class="photo-wrapper">
              <img src={member.photo} alt={member.name} />
            </div>

            <div class="info">
              <h3>{member.name}</h3>
              <p class="role">{member.role}</p>
            </div>

            <div class="divider" />

            <div class="socials">
              <a href={member.github} target="_blank" class="social-link">
                GITHUB
              </a>
              <a href={member.linkedin} target="_blank" class="social-link">
                LINKEDIN
              </a>
              <a href={member.orcid} target="_blank" class="social-link">
                ORCiD
              </a>
              <div class="discord-tag">
                <span class="label">DISCORD:</span>
                <span class="id">{member.discord}</span>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </main>
  <Footer />
</Layout>
