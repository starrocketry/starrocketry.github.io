---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/archive.css";

// 1. Correct the path to look into your markdown folder
// We use './archive/markdown/*.md' because this file is in src/pages/archive.astro
const learningPosts = import.meta.glob("./archive/markdown/*.md", {
  eager: true,
});
const postsArray = Object.values(learningPosts);

const mainCategories = [
  "PROPULSION",
  "AVIONICS",
  "MANUFACTURING",
  "CAD",
  "3D PRINTING",
];
---

<Layout title="Archive | STAR Mission Files">
  <Navbar />
  <main class="archive-container">
    <header class="archive-header">
      <div class="status-tag"><span class="dot"></span> DATABASE_ACTIVE</div>
      <h1>MISSION ARCHIVE</h1>
      <p class="subtitle">
        Filter technical logs by subsystem or browse the full manifest
      </p>
    </header>

    <section class="sorting-grid">
      <button class="sort-card active" data-filter="all">
        <span class="sort-number">// 00</span>
        <span class="sort-label">ALL_FILES</span>
      </button>
      {
        mainCategories.map((cat, index) => (
          <button class="sort-card" data-filter={cat}>
            <span class="sort-number">// 0{index + 1}</span>
            <span class="sort-label">{cat}</span>
          </button>
        ))
      }
    </section>

    <section class="learning-docs">
      <div class="list-header">
        <span class="col">CATEGORY</span>
        <span class="col">DOCUMENT_NAME</span>
        <span class="col">TIMESTAMP</span>
      </div>

      <div class="doc-list" id="document-database">
        {
          postsArray.map((post: any) => {
            // Generate the slug to match your [slug].astro logic
            const slug = post.file.split("/").pop()?.replace(".md", "");
            // Use 'category' or 'tags' from frontmatter for filtering
            const category = post.frontmatter?.category || "GENERAL";

            return (
              <a
                href={`/archive/${slug}`}
                class="doc-item"
                data-category={category}
              >
                <span class="doc-cat">{category}</span>
                <span class="doc-title">
                  {post.frontmatter?.title || "Untitled Document"}
                </span>
                <span class="doc-date">{post.frontmatter?.date || "---"}</span>
              </a>
            );
          })
        }
      </div>
    </section>
  </main>
  <Footer />

  <script>
    const filterButtons = document.querySelectorAll(".sort-card");
    const docItems = document.querySelectorAll(".doc-item");

    filterButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const filter = btn.getAttribute("data-filter")?.toUpperCase() ?? "ALL";

        filterButtons.forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");

        docItems.forEach((item) => {
          const itemCat =
            item.getAttribute("data-category")?.toUpperCase() ?? "";
          if (filter === "ALL" || itemCat === filter) {
            (item as HTMLElement).style.display = "grid";
          } else {
            (item as HTMLElement).style.display = "none";
          }
        });
      });
    });
  </script>
</Layout>
