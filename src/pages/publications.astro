---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

import "../styles/publications.css";

const papers = [
  {
    title: "Performance Analysis of a J Class Solid Rocket Motor",
    journal: "TBA",
    authors: "Abhay Nandan U, Dhruv Kakade, Akshay M, Shanawaz Patil",
    year: "2026",
    doi: "https://doi.org/",
    status: "Accepted for DMMES 2k26 International Conference",
    tags: ["PROPULSION", "TESTING"],
  },
];
---

<Layout title="Publications">
  <Navbar />

  <main class="pub-container">
    <header class="pub-header">
      <div class="header-meta">
        <span class="index-num">// RESEARCH</span>
        <span class="status-indicator"><span class="pulse"></span> ACTIVE</span>
      </div>
      <h1>PUBLICATIONS</h1>
      <p class="description">
        Documented scientific advancements and peer-reviewed contributions to
        aerospace engineering.
      </p>
    </header>

    <section class="pub-list">
      {
        papers.map((paper) => (
          <article class="paper-entry">
            <div class="entry-sidebar">
              <span class="paper-year">{paper.year}</span>
              <span class={`status-badge ${paper.status.toLowerCase()}`}>
                {paper.status}
              </span>
            </div>

            <div class="entry-main">
              <div class="tag-row">
                {paper.tags.map((tag) => (
                  <span class="tag">[{tag}]</span>
                ))}
              </div>
              <h2 class="paper-title">{paper.title}</h2>
              <p class="paper-authors">{paper.authors}</p>
              <p class="paper-journal">
                Published in: <em>{paper.journal}</em>
              </p>

              <div class="action-row">
                <a href={paper.doi} target="_blank" class="doi-link">
                  ACCESS_DOI{" "}
                  <svg
                    width="12"
                    height="12"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3" />
                  </svg>
                </a>
                <button class="cite-btn" onclick="alert('Copied!')">
                  Cite
                </button>
              </div>
            </div>
          </article>
        ))
      }
    </section>
  </main>

  <Footer />
</Layout>
