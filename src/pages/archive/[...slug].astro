---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import "../../styles/project-page.css";

export async function getStaticPaths() {
  // Use a recursive glob (**) to scan deep subfolders under the markdown directory
  const posts = import.meta.glob("./markdown/**/*.md", { eager: true });

  return Object.entries(posts).map(([filePath, post]: [string, any]) => {
    // Converts absolute path strings like "./markdown/ae4l/core/fluid_mechanics.md"
    // into clean URL segment paths: "ae4l/core/fluid_mechanics"
    const slug = filePath.replace(/^\.\/markdown\//, "").replace(/\.md$/, "");

    return {
      params: { slug },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content } = post;
const { title, date, author, tags } = post.frontmatter;
---

<Layout title={`${title} | STAR Archive`}>
  <Navbar />
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/katex@0.17.0/dist/katex.min.css"
    crossorigin="anonymous"
  />

  <article class="project-page" style="padding-top: 120px;">
    <header class="project-hero">
      <div class="hero-bg">
        <img src="/star-text.svg" alt="" />
        <div class="hero-overlay"></div>
      </div>

      <div class="hero-content">
        <nav class="breadcrumb">
          <a href="/archive">&lt; Return To Archive</a>
        </nav>
        <div class="meta-badge">ARCHIVE LOG</div>
        <h1 class="project-title">{title}</h1>
        <div class="project-meta-strip">
          <div class="meta-item">
            <span class="label">OPERATOR</span>
            <span class="value">{author || "UNKNOWN"}</span>
          </div>
          <div class="meta-item">
            <span class="label">TIMESTAMP</span>
            <span class="value">{date || "N/A"}</span>
          </div>
        </div>
      </div>
    </header>

    <div class="project-body-wrapper">
      <aside class="tactical-sidebar">
        <div class="sidebar-box glass">
          <h3>ARCHIVE INFO</h3>
          <ul class="info-list">
            <li>
              <span>TAGS:</span>
              <span class="info-value">
                {
                  tags && Array.isArray(tags)
                    ? tags.join(", ")
                    : tags || "No Tags"
                }
              </span>
            </li>
          </ul>
        </div>
      </aside>

      <section class="markdown-content">
        <Content />

        <div class="doc-footer" style="margin-top: 60px;">
          <a href="/archive" class="back-btn">← RETURN TO FILES</a>
        </div>
      </section>
    </div>
  </article>
  <Footer />
</Layout>

<style is:global>
  /* Regular Content Text Justification */
  .markdown-content p {
    text-align: justify;
    text-justify: inter-word;
    line-height: 1.7;
  }

  /* Video 16:9 AR Lock & "No Crop" Containment */
  .markdown-content video {
    width: 100% !important;
    height: auto !important;
    aspect-ratio: 16 / 9;
    object-fit: contain;
    background-color: #000;
    border: 1px solid rgba(255, 255, 255, 0.05);
    margin: 1.5rem 0;
  }

  /* GFM Table Styling */
  .markdown-content table {
    display: block;
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: 2rem 0;
    border-collapse: collapse;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  .markdown-content th,
  .markdown-content td {
    min-width: 120px;
    padding: 12px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    text-align: left;
  }
  .markdown-content th {
    background: rgba(255, 255, 255, 0.07);
  }

  /* GFM Task List Styling */
  .markdown-content ul li input[type="checkbox"] {
    margin-right: 10px;
    accent-color: #00ffaa;
  }

  /* Math Centering */
  .katex-display {
    margin: 1.5rem 0;
    overflow-x: auto;
    overflow-y: hidden;
  }

  /* Navigation Back Button styling */
  .back-btn {
    display: inline-block;
    color: #fff;
    text-decoration: none;
    font-family: monospace;
    font-size: 0.8rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 10px 20px;
    transition: 0.3s;
  }
  .back-btn:hover {
    background: #00ffaa;
    color: #000;
    border-color: #00ffaa;
  }
</style>
