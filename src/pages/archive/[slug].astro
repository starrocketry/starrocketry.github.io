---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
  // Use Vite's native glob import instead of Astro.glob
  // 'eager: true' loads the content immediately so we can access frontmatter
  const posts = import.meta.glob("./markdown/*.md", { eager: true });

  return Object.values(posts).map((post: any) => {
    // Extract filename for the slug: ./markdown/j-class.md -> j-class
    const slug = post.file.split("/").pop()?.replace(".md", "");

    return {
      params: { slug },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content } = post;
const { title, date, category, author } = post.frontmatter;
---

<Layout title={`${title} | STAR Archive`}>
  <Navbar />

  <main class="reading-container">
    <article class="prose-mission">
      <header class="doc-meta">
        <div class="breadcrumb">
          <a href="/archive">ARCHIVE</a> / <span class="current"
            >{category || "LOGS"}</span
          >
        </div>
        <h1 class="glitch-text">{title}</h1>
        <div class="author-bar">
          <span>OPERATOR: {author || "UNKNOWN"}</span>
          <span class="spacer">|</span>
          <span>TIMESTAMP: {date || "N/A"}</span>
        </div>
      </header>

      <div class="markdown-content">
        <Content />
      </div>

      <div class="doc-footer">
        <a href="/archive" class="back-btn">← RETURN TO FILES</a>
      </div>
    </article>
  </main>

  <Footer />
</Layout>

<style>
  .reading-container {
    background: #000;
    min-height: 100vh;
    padding: 160px 20px 100px;
    color: #ccc;
  }

  .prose-mission {
    max-width: 800px;
    margin: 0 auto;
  }

  .breadcrumb {
    font-family: monospace;
    font-size: 0.7rem;
    letter-spacing: 2px;
    margin-bottom: 20px;
  }

  .breadcrumb a {
    color: #666;
    text-decoration: none;
  }

  .current {
    color: #c594f0;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    color: #fff;
    letter-spacing: -1px;
    margin-bottom: 20px;
    font-family: "Space Grotesk", sans-serif;
  }

  .author-bar {
    font-family: monospace;
    font-size: 0.7rem;
    color: #444;
    border-bottom: 1px solid #111;
    padding-bottom: 30px;
    margin-bottom: 50px;
    display: flex;
    gap: 10px;
  }

  .markdown-content :global(h2) {
    color: #fff;
    font-size: 1.5rem;
    margin-top: 40px;
    border-left: 3px solid #c594f0;
    padding-left: 15px;
  }

  .markdown-content :global(p) {
    line-height: 1.8;
    margin-bottom: 20px;
  }

  .back-btn {
    display: inline-block;
    margin-top: 60px;
    color: #fff;
    text-decoration: none;
    font-family: monospace;
    font-size: 0.8rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 10px 20px;
    transition: 0.3s;
  }

  .back-btn:hover {
    background: #c594f0;
    color: #000;
    border-color: #c594f0;
  }
</style>
