---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import RocketScroll from "../components/RocketScroll.astro";
import SponsorMarquee from "../components/SponsorMarquee.astro"; // The new dual-layer marquee
import Sponsors from "../components/Sponsors.astro";
import Footer from "../components/Footer.astro";
import "../styles/home.css";
---

<Layout title="Ground Control">
  <div id="mission-ui" class="initial-hide">
    <Navbar />
  </div>

  <main>
    <RocketScroll />

    <div id="mission-content" class="initial-hide">
      <div class="section-tag">
        HUGE SHOUT OUT TO OUR MISSION ASSETS (Below given names are AI generated
        therefore not real!)
      </div>

      <SponsorMarquee />

      <div class="command-center">
        <Sponsors />
      </div>

      <Footer />
    </div>
  </main>

  <script is:inline>
    const nav = document.getElementById("mission-ui");
    const content = document.getElementById("mission-content");

    const handleReveal = () => {
      const scroll = window.scrollY;
      const revealPoint = 300;

      if (scroll > revealPoint) {
        // Show Navigation with slide-down
        nav.style.opacity = "1";
        nav.style.visibility = "visible";
        nav.style.transform = "translateY(0)";

        // Reveal the space-centered content
        content.style.opacity = "1";
        content.style.visibility = "visible";
      } else {
        // Hide UI to focus on the Rocket
        nav.style.opacity = "0";
        nav.style.visibility = "hidden";
        nav.style.transform = "translateY(-20px)";

        content.style.opacity = "0";
        content.style.visibility = "hidden";
      }
    };

    window.addEventListener("scroll", handleReveal);
    // Execute on load to check position
    handleReveal();
  </script>
</Layout>
