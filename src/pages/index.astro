---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import RocketScroll from "../components/RocketScroll.astro";
import SponsorMarquee from "../components/SponsorMarquee.astro";
import Sponsors from "../components/Sponsors.astro";
import Footer from "../components/Footer.astro";
import "../styles/home.css";
---

<Layout title="REVA STAR Team">
  <div
    id="mission-ui"
    class="initial-hide"
    style="position: fixed; width: 100%; z-index: 99999; top: 0; left: 0;"
  >
    <Navbar />
  </div>

  <main>
    <RocketScroll />

    <div id="mission-content" class="initial-hide">
      <div class="section-tag">
        HUGE SHOUT OUT TO OUR MISSION ASSETS (Below given names are AI generated
        therefore not real!)
      </div>

      <SponsorMarquee />

      <div class="command-center">
        <Sponsors />
      </div>

      <Footer />
    </div>
  </main>

  <script is:inline>
    const nav = document.getElementById("mission-ui");
    const content = document.getElementById("mission-content");

    const handleReveal = () => {
      const scroll = window.scrollY;
      const revealPoint = 300;

      if (scroll > revealPoint) {
        nav.style.opacity = "1";
        nav.style.visibility = "visible";
        nav.style.transform = "translateY(0)";
        nav.style.pointerEvents = "auto"; // Re-enable clicking the menu

        content.style.opacity = "1";
        content.style.visibility = "visible";
      } else {
        nav.style.opacity = "0";
        nav.style.visibility = "hidden";
        nav.style.transform = "translateY(-20px)";
        nav.style.pointerEvents = "none"; // Let touches pass through to the rocket

        content.style.opacity = "0";
        content.style.visibility = "hidden";
      }
    };

    // Passive listener improves mobile scroll performance
    window.addEventListener("scroll", handleReveal, { passive: true });
    handleReveal();
  </script>
</Layout>
