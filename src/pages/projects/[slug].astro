---
import Layout from "../../layouts/Layout.astro";
import "../../styles/project-page.css";

export async function getStaticPaths() {
  const projectFiles = import.meta.glob("./markdown/*.md", { eager: true });
  return Object.values(projectFiles).map((project: any) => {
    const slug = project.file.split("/").pop()?.replace(".md", "");
    return { params: { slug }, props: { project } };
  });
}

const { project } = Astro.props;
const { Content } = project;
const {
  title,
  id,
  category,
  status,
  image,
  trl,
  testing_type,
  clearance,
  encryption,
} = project.frontmatter;
---

<Layout title={`${title} | Technical Report`}>
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.css"
    crossorigin="anonymous"
  />

  <article class="project-page">
    <header class="project-hero">
      <div class="hero-bg">
        <img src={image} alt="" />
        <div class="hero-overlay"></div>
      </div>

      <div class="hero-content">
        <nav class="breadcrumb">
          <a href="/projects">/PROJECTS</a>
        </nav>
        <div class="meta-badge">PROJECT DOCS</div>
        <h1 class="project-title">{title}</h1>
        <div class="project-meta-strip">
          <div class="meta-item">
            <span class="label">FILE_ID</span>
            <span class="value">{id || "PRJ-UNK"}</span>
          </div>
          <div class="meta-item">
            <span class="label">CATEGORY</span>
            <span class="value">
              {Array.isArray(category) ? category.join(", ") : category}
            </span>
          </div>
          <div class="meta-item">
            <span class="label">STATUS</span>
            <span class={`value status-${status?.toLowerCase()}`}>
              {status || "OPERATIONAL"}
            </span>
          </div>
        </div>
      </div>
    </header>

    <div class="project-body-wrapper">
      <aside class="tactical-sidebar">
        <div class="sidebar-box glass">
          <h3>ARCHIVE_INFO</h3>
          <ul>
            <li>
              <span>TESTING TYPE:</span>
              {testing_type || "GROUND_CONTROL"}
            </li>
            <li><span>CLEARANCE:</span> {clearance || "LEVEL_01"}</li>
            <li><span>ENCRYPTION:</span> {encryption || "NONE"}</li>
          </ul>
        </div>

        <div class="sidebar-box glass">
          <h3>TELEMETRY</h3>
          <div class="stat-row">
            <div class="stat-bar">
              <div class="fill" style={`width: ${trl || 0}%;`}></div>
            </div>
            <span class="stat-label">TRL {trl || 0}%</span>
          </div>
        </div>
      </aside>

      <section class="markdown-content">
        <Content />
      </section>
    </div>
  </article>
</Layout>

<style is:global>
  /* GFM Table Styling */
  .markdown-content table {
    width: 100%;
    margin: 2rem 0;
    border-collapse: collapse;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  .markdown-content th,
  .markdown-content td {
    padding: 12px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    text-align: left;
  }
  .markdown-content th {
    background: rgba(255, 255, 255, 0.07);
  }

  /* GFM Task List Styling */
  .markdown-content ul li input[type="checkbox"] {
    margin-right: 10px;
    accent-color: #00ffaa;
  }

  /* Math Centering */
  .katex-display {
    margin: 1.5rem 0;
    overflow-x: auto;
    overflow-y: hidden;
  }
</style>
