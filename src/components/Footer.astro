---
import "../styles/footer.css";
const currentYear = new Date().getFullYear();
// Google Maps Link for REVA University
const mapsLink =
  "https://www.google.com/maps/dir//REVA+UNIVERSITY,+Rukmini+Knowledge+Park,+Kattigenahalli,+Yelahanka,+Bengaluru,+Karnataka+560064";
---

<footer class="mission-footer glass">
  <div class="footer-grid">
    <div class="footer-brand">
      <div class="logo-stack">
        <img class="name-svg" src="/star-text.svg" alt="STAR" />
        <span class="tagline"
          >STARTED THE LEGACY OF ROCKETRY AT REVA UNIVERSITY</span
        >
      </div>
    </div>

    <div class="footer-nav">
      <div class="nav-group">
        <label>SYSTEMS</label>
        <div class="link-list">
          <a href="/archive">RESOURCE ARCHIVE</a>
          <a href="/personnel">PERSONNEL</a>
        </div>
      </div>

      <div class="nav-group">
        <label>COORDINATES</label>
        <a
          href={mapsLink}
          target="_blank"
          rel="noopener noreferrer"
          class="address-link"
        >
          <address class="address-box">
            REVA University, Yelahanka,<br />
            Bangalore, KA 560064
          </address>
          <div class="geo-coords">13.11692°N, 77.63461°E</div>
        </a>
      </div>

      <div class="nav-group">
        <label>SOCIAL UPLINK</label>
        <div class="social-wrapper">
          <a
            href="https://instagram.com"
            class="social-icon"
            target="_blank"
            aria-label="Instagram"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><rect x="2" y="2" width="20" height="20" rx="5" ry="5"
              ></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
              ></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg
            >
          </a>
          <a
            href="https://linkedin.com"
            class="social-icon"
            target="_blank"
            aria-label="LinkedIn"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><path
                d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
              ></path><rect x="2" y="9" width="4" height="12"></rect><circle
                cx="4"
                cy="4"
                r="2"></circle></svg
            >
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="status-indicator">
      <div class="pulse-container">
        <div class="pulse-core"></div>
        <div class="pulse-ring"></div>
      </div>
      <span class="status-text">SYSTEMS_NOMINAL</span>
    </div>
    <p class="legal">
      © {currentYear} STAR ROCKETRY TEAM, REVA UNIVERSITY
    </p>
  </div>
</footer>
