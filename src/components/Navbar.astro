---
import "../styles/navbar.css";
---

<nav class="navbar">
  <div class="logo">
    <a href="/">
      <img
        src="/star-text.svg"
        alt="STAR Logo"
        class="nav-logo"
        style="width: 75px;"
      />
    </a>
  </div>

  <div class="links desktop-only">
    <a href="/">HOME</a>
    <a href="/about">ABOUT</a>
    <a href="/projects">PROJECTS</a>
    <a href="/publications">PUBLICATIONS</a>
    <a href="/personnel">PERSONNEL</a>
  </div>

  <button
    id="menu-toggle"
    class="mobile-only"
    aria-label="Toggle Menu"
    style="z-index: 100001;"
  >
    <div class="hamburger-box">
      <span class="line top"></span>
      <span class="line bottom"></span>
    </div>
  </button>

  <div id="mobile-menu" class="mobile-overlay">
    <div class="scan-line"></div>

    <div class="overlay-content">
      <div class="overlay-links">
        <a href="/" style="--i:1">HOME</a>
        <a href="/about" style="--i:2">ABOUT</a>
        <a href="/projects" style="--i:3">PROJECTS</a>
        <a href="/publications" style="--i:4">PUBLICATIONS</a>
        <a href="/personnel" style="--i:5">PERSONNEL</a>
      </div>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");

  const toggleMenu = (forceClose = false) => {
    const isOpening = forceClose
      ? false
      : !menu?.classList.contains("is-visible");

    toggle?.classList.toggle("is-active", isOpening);
    menu?.classList.toggle("is-visible", isOpening);

    // Manage touch layers without freezing the browser scroll
    if (menu) {
      menu.style.pointerEvents = isOpening ? "auto" : "none";
    }
  };

  toggle?.addEventListener("click", () => toggleMenu());

  document.querySelectorAll(".overlay-links a").forEach((link) => {
    link.addEventListener("click", () => toggleMenu(true));
  });
</script>
